    {
      "pattern_id": "rule_daily_grain_retention_policy",
      "version": 1,
      "source_traces": [
        "qa_2025-12-30_002"
      ],
      "created": "2025-12-31T00:00:00Z",
      "last_updated": "2025-12-31T00:00:00Z",
      "confidence": "medium",
      "pattern": {
        "generalized_symptom": "0 rows returned for Daily grain validation on historical data older than the retention window",
        "error_types": [
          "missing_rows"
        ],
        "contexts": [
          "migration",
          "incremental_testing"
        ],
        "detection_signals": [
          "0 rows",
          "Daily",
          "grain",
          "historical",
          "retention",
          "missing data"
        ]
      },
      "recommended_action": {
        "first_try": "Switch validation to Monthly grain when Daily data is outside the retention window",
        "rationale": "Some marts intentionally retain Daily grain data for a shorter period than Monthly grain.",
        "implementation": {
          "file_pattern": "*.sql",
          "change": "WHERE time_period = 'Monthly' -- Daily only kept 21 days"
        },
        "alternatives": [
          "Validate with recent dates",
          "Check the mart retention policy",
          "Confirm the retention expectation with stakeholders"
        ]
      },
      "applicability": {
        "when_applicable": [
          "Validating marts with a time_period column",
          "Historical data validation older than the Daily retention window",
          "0 rows on Daily but Monthly has data"
        ],
        "when_not_applicable": [
          "Recent data",
          "Models without retention policies",
          "Missing data across all grains"
        ]
      },
